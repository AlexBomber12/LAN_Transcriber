+            <input type="hidden" name="diar_speaker_label" value="{{ row.speaker }}">
+            <select name="voice_profile_id" style="width:180px">
+              {% for vp in profiles %}
+              <option value="{{ vp.id }}" {% if row.voice_profile_id == vp.id %}selected{% endif %}>{{ vp.display_name }}</option>
