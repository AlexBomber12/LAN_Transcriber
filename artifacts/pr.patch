+        model_name: str,
+        device: str,
+        compute_type: str = "int8",
+        vad_model: str = "silero",
+    ) -> _FakeModel:
+        assert model_name == "large-v3"
+        assert device == "cpu"
+        assert compute_type == "int8"
+        assert vad_model == "pyannote"
+        return _FakeModel()
+
+    fake_whisperx.load_audio = _load_audio
+    fake_whisperx.load_model = _load_model
