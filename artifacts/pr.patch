diff --git a/lan_app/templates/partials/control_center/system_bar.html b/lan_app/templates/partials/control_center/system_bar.html
new file mode 100644
index 0000000..5f55994
--- /dev/null
+++ b/lan_app/templates/partials/control_center/system_bar.html
@@ -0,0 +1,23 @@
+<footer id="control-center-system-bar" class="control-center-system-bar">
+  <div class="control-center-system-group">
+    {% for item in control_center_system_bar.primary_items %}
+    <div class="control-center-system-item">
+      <span class="control-center-system-label">{{ item.label }}</span>
+      <strong class="control-center-system-value">{{ item.value }}</strong>
+      <span class="control-center-system-detail">{{ item.detail }}</span>
+    </div>
+    {% endfor %}
+  </div>
+
+  <div class="control-center-system-group control-center-system-group-secondary">
+    {% for item in control_center_system_bar.secondary_items %}
+    <div class="control-center-system-item{% if item.placeholder %} placeholder{% endif %}">
+      <span class="control-center-system-label">{{ item.label }}</span>
+      <strong class="control-center-system-value">{{ item.value }}</strong>
+      <span class="control-center-system-detail">{{ item.detail }}</span>
+    </div>
+    {% endfor %}
+  </div>
+
+  <p class="control-center-system-note">{{ control_center_system_bar.note }}</p>
+</footer>
diff --git a/lan_app/templates/partials/control_center/workspace_header.html b/lan_app/templates/partials/control_center/workspace_header.html
new file mode 100644
index 0000000..0df86c6
--- /dev/null
+++ b/lan_app/templates/partials/control_center/workspace_header.html
@@ -0,0 +1,52 @@
+<section id="control-center-workspace-header" class="control-center-workspace-header">
+  <div class="control-center-workspace-copy">
+    <p class="eyebrow">Daily workspace</p>
+    <h1>Control Center</h1>
+    <p>
+      Upload new audio, work the queue, and keep the current review in view without
+      falling back to the full-page inspector unless you need deeper diagnostics.
+    </p>
+  </div>
+
+  <aside class="control-center-focus-card">
+    <div class="control-center-focus-topline">
+      <span class="control-center-focus-label">Compact inspector</span>
+      <span class="control-center-focus-state{% if control_center_state.selected %} active{% endif %}">
+        {% if control_center_state.selected %}Active{% else %}Waiting{% endif %}
+      </span>
+    </div>
+
+    {% if control_center_state.selected and rec is defined %}
+    <strong class="control-center-focus-title">{{ rec.source_filename }}</strong>
+    <p class="control-center-focus-copy">
+      <code>{{ rec.id }}</code> · {{ rec.status }} · {{ control_center_state.tab_label }} tab
+    </p>
+    {% elif control_center_state.selected %}
+    <strong class="control-center-focus-title">{{ control_center_state.selected }}</strong>
+    <p class="control-center-focus-copy">Selected from the worklist. The compact inspector keeps the shell focused here.</p>
+    {% else %}
+    <strong class="control-center-focus-title">No recording selected</strong>
+    <p class="control-center-focus-copy">Pick a row from the worklist to open overview, speakers, and quick actions on the right.</p>
+    {% endif %}
+
+    <div class="control-center-focus-pills">
+      <span class="control-center-focus-pill">{{ control_center_work_pane.recordings_panel.total }} visible</span>
+      <span class="control-center-focus-pill">{{ control_center_state.status or "All statuses" }}</span>
+      {% if control_center_state.q %}
+      <span class="control-center-focus-pill">Search: {{ control_center_state.q }}</span>
+      {% endif %}
+    </div>
+
+    <div class="control-center-focus-actions">
+      {% if control_center_state.selected %}
+      <a href="{{ control_center_state.clear_selection_href }}" class="btn">Clear selection</a>
+      {% endif %}
+      {% if control_center_state.status or control_center_state.q %}
+      <a href="{{ control_center_state.reset_href }}" class="btn">Reset queue view</a>
+      {% endif %}
+      {% if control_center_work_pane.workflow_links.selected_detail_href %}
+      <a href="{{ control_center_work_pane.workflow_links.selected_detail_href }}" class="btn">Open full-page inspector</a>
+      {% endif %}
+    </div>
+  </aside>
+</section>
