+    atomic_write_json(ctx.artifacts.asr_execution_json_path, ctx.asr_execution)
+    return _StageResult(
+        status="completed",
+        metadata={
+            "segment_count": len(ctx.asr_segments),
+            "used_multilingual_path": bool(ctx.asr_execution.get("used_multilingual_path")),
