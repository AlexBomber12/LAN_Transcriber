+    class _SyncClient:
+        identity = "sync-client"
+
+        def generate(self, *_args, **_kwargs):
+            return {"status": "ok"}
+
+    sync_client = worker_tasks._CancelAwareLLMClient(  # noqa: SLF001
+        base_client=_SyncClient(),
