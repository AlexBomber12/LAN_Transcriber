+          <td>{{ candidate.starts_at_display }} → {{ candidate.ends_at_display }}</td>
+          <td>{{ candidate.source_label }}</td>
+          <td>
+            {{ candidate.confidence_display }}
+            {% if candidate.selected %}
+            <div style="margin-top:4px"><span class="badge s-Ready">Selected</span></div>
+            {% endif %}
+          </td>
+          <td title="{{ candidate.attendees_label }}">{{ candidate.attendees_label }}</td>
+          <td style="white-space:normal;max-width:320px">
+            {% if candidate.rationale_rows %}
+              {% for reason in candidate.rationale_rows %}
+              <div>{{ reason }}</div>
+              {% endfor %}
+            {% else %}
+            —
+            {% endif %}
+          </td>
+          <td>
+            {% if candidate.selected %}
