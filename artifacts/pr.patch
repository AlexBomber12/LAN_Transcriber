+            Candidates:
+            {% for candidate in row.candidate_matches %}
+            <span>{{ candidate.display_name }} ({{ '%.2f'|format(candidate.score) }}){% if not loop.last %}, {% endif %}</span>
+            {% endfor %}
+          </div>
+          {% endif %}
