+
+    payload = worker_tasks._build_diarization_metadata_payload(  # noqa: SLF001
+        runtime={"mode": "pyannote"},
+        cfg=cfg,
+        smoothing_result=smoothing_result,
+    )
+    assert payload["pr140_simulated_new_field"] == "present"
