+    assert system_status._probe_spark_runtime(_settings(tmp_path))["state"] == "degraded"
+
+    monkeypatch.setattr(
+        system_status.httpx,
+        "Client",
+        _client_factory(_FakeResponse(401, {})),
+    )
+    assert system_status._probe_spark_runtime(_settings(tmp_path))["value"] == "Auth error"
