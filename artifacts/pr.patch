+  {% include "partials/control_center/recordings_status_cards.html" %}
+  {% set recordings_filters = recordings_panel.recordings_filters %}
+  {% include "partials/control_center/recordings_filters.html" %}
+  {% set recordings_table = recordings_panel.recordings_table %}
+  {% include "partials/control_center/recordings_table.html" %}
+</div>
