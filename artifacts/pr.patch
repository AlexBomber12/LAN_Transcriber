diff --git a/lan_app/templates/partials/control_center/work_pane.html b/lan_app/templates/partials/control_center/work_pane.html
new file mode 100644
index 0000000..bcca7ee
--- /dev/null
+++ b/lan_app/templates/partials/control_center/work_pane.html
@@ -0,0 +1,88 @@
+<div class="control-center-pane-head">
+  <div>
+    <h2 style="margin-top:0">Work Pane</h2>
+    <p class="control-center-pane-copy">
+      This pane will become the live operator list. For now it previews recent recordings and preserves list state in the URL.
+    </p>
+  </div>
+  <div class="filters" style="margin:0">
+    <a href="/upload" class="btn" style="text-decoration:none">Upload file</a>
+    <a href="{{ control_center_state.recordings_href }}" class="btn" style="text-decoration:none">Full list</a>
+  </div>
+</div>
+
+<form id="control-center-state-form" class="filters" method="get" action="/" hx-boost="false">
+  <label for="control-center-status">Status:</label>
+  <select id="control-center-status" name="status">
+    <option value="">All</option>
+    {% for status_option in control_center_state.status_options %}
+    <option value="{{ status_option }}" {% if control_center_state.status == status_option %}selected{% endif %}>{{ status_option }}</option>
+    {% endfor %}
+  </select>
+
+  <label for="control-center-search">Search:</label>
+  <input
+    id="control-center-search"
+    type="search"
+    name="q"
+    value="{{ control_center_state.q }}"
+    placeholder="ID or filename"
+  >
+
+  <label for="control-center-tab">Inspector tab:</label>
+  <select id="control-center-tab" name="tab">
+    {% for tab_option in control_center_state.tab_options %}
+    <option value="{{ tab_option.value }}" {% if tab_option.selected %}selected{% endif %}>{{ tab_option.label }}</option>
+    {% endfor %}
+  </select>
+
+  <input type="hidden" name="selected" value="{{ control_center_state.selected }}">
+  <button class="btn" type="submit">Apply</button>
+  <a href="{{ control_center_state.reset_href }}" class="btn" style="text-decoration:none">Reset</a>
+</form>
+
+<p class="control-center-preview-note">{{ control_center_work_pane.preview_message }}</p>
+
+{% if control_center_work_pane.rows %}
+<table>
+  <thead>
+    <tr>
+      <th>Pick</th>
+      <th>Recording</th>
+      <th>Status</th>
+      <th>Captured</th>
+      <th>Open</th>
+    </tr>
+  </thead>
+  <tbody>
+    {% for row in control_center_work_pane.rows %}
+    <tr>
+      <td>
+        {% if row.selected %}
+        <span class="badge s-Ready">Selected</span>
+        {% else %}
+        <a href="{{ row.select_href }}" class="btn" style="text-decoration:none">Select</a>
+        {% endif %}
+      </td>
+      <td title="{{ row.id }}">
+        <strong>{{ row.source_filename or row.id }}</strong><br>
+        <span style="color:#666">{{ row.id }}</span>
+      </td>
+      <td><span class="badge s-{{ row.status }}">{{ row.status }}</span></td>
+      <td>{{ row.captured_at_display }}</td>
+      <td>
+        <div class="control-center-row-actions">
+          <a href="{{ row.detail_href }}" class="btn" style="text-decoration:none">Full page</a>
+        </div>
+      </td>
+    </tr>
+    {% endfor %}
+  </tbody>
+</table>
+{% else %}
+<p class="placeholder">No recent recordings match this preview. Upload a file or open the full recordings page.</p>
+{% endif %}
+
+<p class="control-center-preview-note" style="margin-top:10px">
+  Preview limit: {{ control_center_work_pane.preview_limit }} rows.
+</p>
