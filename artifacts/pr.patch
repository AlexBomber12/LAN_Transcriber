+      <h2 style="margin-top:0">{{ recordings_panel.title }}</h2>
+      <p class="control-center-pane-copy">{{ recordings_panel.description }}</p>
+    </div>
+    <div class="control-center-state-list" style="margin-top:0">
+      <span class="control-center-state-pill">Rows: {{ recordings_panel.total }}</span>
+      <span class="control-center-state-pill">Limit: {{ recordings_panel.recordings_table.limit }}</span>
+      <span class="control-center-state-pill">
+        Search: {{ recordings_panel.recordings_filters.search_query or "None" }}
+      </span>
