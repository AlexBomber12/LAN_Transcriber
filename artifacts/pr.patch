+    segments, merge_map, diagnostics = worker_tasks._apply_speaker_merge_step(  # noqa: SLF001
+        diarization_segments=[
+            {"speaker": "S1", "start": 0.0, "end": 1.0},
+            {"speaker": "S2", "start": 1.0, "end": 2.0},
+        ],
