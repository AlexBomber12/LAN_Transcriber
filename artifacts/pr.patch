+                "pad_seconds": 0.25,
+                "max_clip_duration_seconds": 8.0,
+                "min_clip_duration_seconds": 0.8,
+                "max_snippets_per_speaker": 3,
+                "accepted_snippets": 1,
+                "speaker_count": 1,
+                "warning_count": 0,
+                "speakers": {
