@@ -0,0 +1,89 @@
+{% set sp = speakers or {} %}
+{% set rows = sp.speaker_rows or [] %}
+{% set profiles = sp.voice_profiles or [] %}
+{% set notices = sp.review_notices or [] %}
+{% set repair = sp.snippet_repair or {} %}
+
+<section class="inspector-section-card">
+  <div class="inspector-section-head">
+    <div>
+      <p class="eyebrow">Speaker Review Workspace</p>
+      <h2>Speakers</h2>
+      <p class="inspector-note">Review speakers through their best clean clips first. The compact Control Center stays faster and smaller; this page keeps the richer review flow.</p>
+    </div>
+    <div class="embedded-card-actions">
+      <a href="{{ sp.manage_voices_href or '/voices' }}" class="btn" style="text-decoration:none">Open canonical speakers page</a>
+    </div>
+  </div>
+
+  {% if sp.notice_message %}
+  <div class="page-notice">{{ sp.notice_message }}</div>
+  {% endif %}
+  {% if sp.error_message %}
+  <div class="page-notice">{{ sp.error_message }}</div>
+  {% endif %}
+  {% if repair.detail %}
+  <div class="page-notice">
+    <div style="margin-bottom:{% if repair.available %}8px{% else %}0{% endif %}">
+      {{ repair.detail }}
+    </div>
+    {% if repair.available %}
+    <form method="post" action="/ui/recordings/{{ rec.id }}/speakers/regenerate-snippets">
+      <button class="btn" type="submit">{{ repair.button_label }}</button>
+    </form>
+    {% endif %}
+  </div>
+  {% endif %}
+  {% if notices %}
+    {% for notice in notices %}
+    <div class="page-notice">{{ notice }}</div>
+    {% endfor %}
+  {% endif %}
+
+  <section class="embedded-card">
+    <p class="inspector-note">
+      <strong>Confirm match</strong> changes canonical identity across recordings.
+      <strong>Keep unknown</strong> closes review without naming the speaker.
+      <strong>Local label only</strong> changes the name only for this recording.
+      <strong>Add trusted sample</strong> is training-only and stays separate from identity mapping.
+    </p>
+  </section>
+
+  {% set speaker_review_mode = 'full' %}
+  {% include 'partials/speaker_review_cards.html' %}
+</section>
+
+<section class="inspector-section-card">
+  <div class="inspector-section-head">
+    <div>
+      <h2>Create Canonical Speaker</h2>
+      <p class="inspector-note">Create a new canonical person and confirm the diarized match in one step.</p>
+    </div>
+  </div>
+  {% if rows %}
+  <form method="post" action="/ui/recordings/{{ rec.id }}/speakers/create-and-assign">
+    <div class="form-row">
+      <label for="diar_speaker_label">Speaker label</label>
+      <select id="diar_speaker_label" name="diar_speaker_label" style="width:180px">
+        {% for row in rows %}
+        <option value="{{ row.speaker }}">{{ row.speaker }}</option>
+        {% endfor %}
+      </select>
+    </div>
+    <div class="form-row">
+      <label for="display_name">Display name</label>
+      <input id="display_name" type="text" name="display_name" maxlength="120" required placeholder="Person name" style="width:260px">
+    </div>
+    <div class="form-row">
+      <label for="notes">Notes</label>
+      <input id="notes" type="text" name="notes" maxlength="240" placeholder="Optional notes" style="width:360px">
+    </div>
+    <div class="form-row">
+      <label></label>
+      <button class="btn" type="submit">Create and confirm match</button>
+    </div>
+  </form>
+  {% else %}
+  <p class="placeholder">No diarization labels are available for assignment.</p>
+  {% endif %}
+</section>
diff --git a/lan_app/templates/partials/recording_inspector_full_summary.html b/lan_app/templates/partials/recording_inspector_full_summary.html
new file mode 100644
index 0000000..59361f7
--- /dev/null
+++ b/lan_app/templates/partials/recording_inspector_full_summary.html
@@ -0,0 +1,219 @@
+{% set summary_data = summary or {} %}
+{% set metrics_data = metrics or {} %}
+{% set meeting = metrics_data.meeting or {} %}
+{% set participants = metrics_data.participants or [] %}
+{% set questions = summary_data.questions or {} %}
+{% set question_types = questions.types or {} %}
+
+<div class="summary-section-grid">
+  <section class="inspector-section-card">
+    <div class="inspector-section-head">
+      <div>
+        <p class="eyebrow">Meeting Output</p>
+        <h2>Summary</h2>
+        <p class="inspector-note">Summary, decisions, actions, questions, and conversation metrics stay together here instead of competing with Overview.</p>
+      </div>
+    </div>
+
+    <div class="embedded-panel-grid">
+      <section class="embedded-card">
+        <h3>Topic</h3>
+        <p class="inspector-answer">{{ summary_data.topic or '—' }}</p>
+      </section>
+      <section class="embedded-card">
+        <h3>Emotional summary</h3>
+        <p class="inspector-note">{{ summary_data.emotional_summary or meeting.emotional_summary or 'No emotional summary was extracted.' }}</p>
+      </section>
+    </div>
+
+    <section class="embedded-card">
+      <div class="embedded-card-head">
+        <div>
+          <h3>Summary bullets</h3>
+        </div>
+      </div>
+      {% if summary_data.summary_bullets %}
+      <ul class="summary-list">
+        {% for bullet in summary_data.summary_bullets %}
+        <li>{{ bullet }}</li>
+        {% endfor %}
+      </ul>
+      {% elif summary_data.summary_text %}
+      <pre class="transcript-plain-text">{{ summary_data.summary_text }}</pre>
+      {% else %}
+      <p class="placeholder">No summary is available yet.</p>
+      {% endif %}
+    </section>
+  </section>
+
+  <section class="inspector-section-card">
+    <div class="inspector-section-head">
+      <div>
+        <h2>Meeting Metrics</h2>
+        <p class="inspector-note">These meeting-level signals stay adjacent to the summary so the page reads as one output surface.</p>
+      </div>
+    </div>
+    <div class="summary-kpi-grid">
+      <div class="compact-metadata-item">
+        <span class="compact-metadata-label">Speech time</span>
+        <strong class="compact-metadata-value">{{ '%.1f'|format(meeting.total_speech_time_seconds or 0.0) }}s</strong>
+      </div>
+      <div class="compact-metadata-item">
+        <span class="compact-metadata-label">Interruptions</span>
+        <strong class="compact-metadata-value">{{ meeting.total_interruptions or 0 }}</strong>
+      </div>
+      <div class="compact-metadata-item">
+        <span class="compact-metadata-label">Questions</span>
+        <strong class="compact-metadata-value">{{ meeting.total_questions or 0 }}</strong>
+      </div>
+      <div class="compact-metadata-item">
+        <span class="compact-metadata-label">Decisions</span>
+        <strong class="compact-metadata-value">{{ meeting.decisions_count or 0 }}</strong>
+      </div>
+      <div class="compact-metadata-item">
+        <span class="compact-metadata-label">Action items</span>
+        <strong class="compact-metadata-value">{{ meeting.action_items_count or 0 }}</strong>
+      </div>
+      <div class="compact-metadata-item">
+        <span class="compact-metadata-label">Actionability</span>
+        <strong class="compact-metadata-value">{{ '%.1f'|format((meeting.actionability_ratio or 0.0) * 100.0) }}%</strong>
+      </div>
+    </div>
+  </section>
+</div>
+
+<div class="summary-section-grid">
+  <section class="inspector-section-card">
+    <div class="inspector-section-head">
+      <div>
+        <h2>Decisions</h2>
+      </div>
+    </div>
+    {% if summary_data.decisions %}
+    <ul class="summary-list">
+      {% for decision in summary_data.decisions %}
+      <li>{{ decision }}</li>
+      {% endfor %}
+    </ul>
+    {% else %}
+    <p class="placeholder">No decisions were extracted.</p>
+    {% endif %}
+  </section>
+
+  <section class="inspector-section-card">
+    <div class="inspector-section-head">
+      <div>
+        <h2>Action items</h2>
+      </div>
+    </div>
+    {% if summary_data.action_items %}
+    <table>
+      <thead>
+        <tr>
+          <th>Task</th>
+          <th>Owner</th>
+          <th>Deadline</th>
+          <th>Confidence</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for item in summary_data.action_items %}
+        <tr>
+          <td>{{ item.task }}</td>
+          <td>{{ item.owner or '—' }}</td>
+          <td>{{ item.deadline or '—' }}</td>
+          <td>{{ '%.2f'|format(item.confidence or 0.0) }}</td>
+        </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+    {% else %}
+    <p class="placeholder">No action items were extracted.</p>
+    {% endif %}
+  </section>
+</div>
+
+<section class="inspector-section-card">
+  <div class="inspector-section-head">
+    <div>
+      <h2>Questions</h2>
+      <p class="inspector-note">Question types remain part of the extracted meeting output instead of living in the diagnostics surface.</p>
+    </div>
+  </div>
+  <div class="summary-kpi-grid">
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Total</span>
+      <strong class="compact-metadata-value">{{ questions.total_count or 0 }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Open</span>
+      <strong class="compact-metadata-value">{{ question_types.open or 0 }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Yes / no</span>
+      <strong class="compact-metadata-value">{{ question_types.yes_no or 0 }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Clarification</span>
+      <strong class="compact-metadata-value">{{ question_types.clarification or 0 }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Status</span>
+      <strong class="compact-metadata-value">{{ question_types.status or 0 }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Decision-seeking</span>
+      <strong class="compact-metadata-value">{{ question_types.decision_seeking or 0 }}</strong>
+    </div>
+  </div>
+  {% if questions.extracted %}
+  <ul class="summary-list">
+    {% for question in questions.extracted %}
+    <li>{{ question }}</li>
+    {% endfor %}
+  </ul>
+  {% else %}
+  <p class="placeholder">No extracted questions are available.</p>
+  {% endif %}
+</section>
+
+<section class="inspector-section-card">
+  <div class="inspector-section-head">
+    <div>
+      <h2>Participants</h2>
+      <p class="inspector-note">Participant metrics stay available here when the conversation metrics artifact exists.</p>
+    </div>
+  </div>
+  {% if participants %}
+  <table>
+    <thead>
+      <tr>
+        <th>Speaker</th>
+        <th>Airtime (s)</th>
+        <th>Share (%)</th>
+        <th>Turns</th>
+        <th>Interruptions done</th>
+        <th>Interruptions received</th>
+        <th>Questions</th>
+        <th>Role</th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for row in participants %}
+      <tr>
+        <td>{{ row.speaker }}</td>
+        <td>{{ '%.2f'|format(row.airtime_seconds or 0.0) }}</td>
+        <td>{{ '%.2f'|format((row.airtime_share or 0.0) * 100.0) }}</td>
+        <td>{{ row.turns or 0 }}</td>
+        <td>{{ row.interruptions_done or 0 }}</td>
+        <td>{{ row.interruptions_received or 0 }}</td>
+        <td>{{ row.questions_count or 0 }}</td>
+        <td>{{ row.role_hint or '—' }}</td>
+      </tr>
+      {% endfor %}
+    </tbody>
+  </table>
+  {% else %}
+  <p class="placeholder">No participant metrics are available yet.</p>
+  {% endif %}
+</section>
diff --git a/lan_app/templates/partials/recording_inspector_full_transcript.html b/lan_app/templates/partials/recording_inspector_full_transcript.html
new file mode 100644
index 0000000..cced7ea
--- /dev/null
+++ b/lan_app/templates/partials/recording_inspector_full_transcript.html
@@ -0,0 +1,86 @@
+{% set tr = transcript or {} %}
+<section class="inspector-section-card transcript-section-card">
+  <div class="inspector-section-head">
+    <div>
+      <p class="eyebrow">Transcript Workspace</p>
+      <h2>Transcript</h2>
+      <p class="inspector-note">This tab gives the transcript a wider, calmer reading surface than the compact Control Center pane.</p>
+    </div>
+    <div class="embedded-card-actions">
+      <button type="button" class="btn" onclick="copyInspectorFieldText('transcript-copy-text', 'transcript-copy-status', 'Copied transcript text.', 'Copy failed. Select the text and copy manually.')">Copy transcript</button>
+      <a href="{{ tr.quick_add_href or ('/glossary?recording_id=' ~ rec.id) }}" class="btn">Add correction from this recording</a>
+      <a href="{{ tr.manage_corrections_href or '/glossary' }}" class="btn">Manage corrections</a>
+    </div>
+  </div>
+
+  <div class="compact-metadata-grid">
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Source</span>
+      <strong class="compact-metadata-value">{{ tr.source_label or 'Transcript text' }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Dominant language</span>
+      <strong class="compact-metadata-value">{{ tr.dominant_language_label or 'Unknown' }}</strong>
+    </div>
+    <div class="compact-metadata-item">
+      <span class="compact-metadata-label">Visible blocks</span>
+      <strong class="compact-metadata-value">{{ tr.turn_count if tr.turn_count is not none else 0 }}</strong>
+    </div>
+  </div>
+
+  {% if tr.available %}
+  <div id="recording-transcript-panel" class="transcript-scroll-panel" data-testid="recording-transcript-panel">
+    {% if tr.turns %}
+      {% for turn in tr.turns %}
+      <article class="transcript-turn">
+        <div class="transcript-turn-meta">
+          <strong class="transcript-turn-speaker">{{ turn.speaker }}</strong>
+          <span>{{ turn.time_range }}</span>
+          {% if turn.language_label %}
+          <span>{{ turn.language_label }}</span>
+          {% endif %}
+        </div>
+        <p class="transcript-turn-text">{{ turn.text }}</p>
+      </article>
+      {% endfor %}
+    {% else %}
+    <pre class="transcript-plain-text">{{ tr.raw_text }}</pre>
+    {% endif %}
+  </div>
+  <textarea id="transcript-copy-text" class="inspector-copy-store" readonly>{{ tr.copy_text or tr.raw_text or '' }}</textarea>
+  <p id="transcript-copy-status" class="inspector-note">Copy the transcript text or jump to Corrections when a name or phrase needs to be remembered.</p>
+  {% else %}
+  <p class="placeholder">Transcript content is not available for this recording yet.</p>
+  {% endif %}
+</section>
+
+<script>
+if (!window.copyInspectorFieldText) {
+  window.copyInspectorFieldText = function(fieldId, statusId, successMessage, failureMessage) {
+    var textarea = document.getElementById(fieldId);
+    var status = document.getElementById(statusId);
+    if (!textarea) return;
+    var setStatus = function(message) {
+      if (status) status.textContent = message;
+    };
+    var fallback = function() {
+      textarea.focus();
+      textarea.select();
+      try {
+        document.execCommand('copy');
+        setStatus(successMessage);
+      } catch (_err) {
+        setStatus(failureMessage);
+      }
+    };
+    if (navigator.clipboard && navigator.clipboard.writeText) {
+      navigator.clipboard.writeText(textarea.value).then(
+        function() { setStatus(successMessage); },
+        fallback
+      );
+      return;
+    }
+    fallback();
+  };
+}
+</script>
