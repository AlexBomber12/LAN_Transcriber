+function syncControlCenterShellRefreshUrlsFromStateParams(stateParams) {
+  if (!stateParams) {
+    return;
+  }
+  var normalizedParams = new URLSearchParams();
+  normalizedParams.set('selected', stateParams.get('selected') || '');
+  normalizedParams.set('status', stateParams.get('status') || '');
+  normalizedParams.set('q', stateParams.get('q') || '');
+  normalizedParams.set('tab', stateParams.get('tab') || 'overview');
+  normalizedParams.set('limit', stateParams.get('limit') || '25');
+  normalizedParams.set('offset', stateParams.get('offset') || '0');
+  var workspaceHeaderUrl = '/ui/control-center/workspace-header?' + normalizedParams.toString();
+  var systemBarUrl = '/ui/control-center/system-bar?' + normalizedParams.toString();
+  var panel = document.getElementById('control-center-recordings-panel');
+  var header = document.getElementById('control-center-workspace-header');
+  var systemBar = document.getElementById('control-center-system-bar');
+  if (panel) {
+    panel.setAttribute('data-workspace-header-url', workspaceHeaderUrl);
+    panel.setAttribute('data-system-bar-url', systemBarUrl);
+  }
+  if (header) {
+    header.setAttribute('hx-get', workspaceHeaderUrl);
+  }
+  if (systemBar) {
+    systemBar.setAttribute('hx-get', systemBarUrl);
+  }
+}
+
+function syncControlCenterShellRefreshUrlsFromHref(href) {
+  if (!href) {
+    syncControlCenterShellRefreshUrlsFromStateParams(new URLSearchParams(window.location.search || ''));
+    return;
+  }
+  syncControlCenterShellRefreshUrlsFromStateParams(
+    new URL(href, window.location.origin).searchParams
+  );
+}
