+def _settings(tmp_path: Path, **overrides: Any) -> pipeline.Settings:
+    defaults = {
+        "speaker_db": tmp_path / "db.yaml",
+        "tmp_root": tmp_path / "tmp",
+        "recordings_root": tmp_path / "recordings",
+    }
+    defaults.update(overrides)
