diff --git a/lan_app/templates/partials/control_center/recordings_table.html b/lan_app/templates/partials/control_center/recordings_table.html
new file mode 100644
index 0000000..67d84bd
--- /dev/null
+++ b/lan_app/templates/partials/control_center/recordings_table.html
@@ -0,0 +1,95 @@
+{% if recordings_table.rows %}
+<table>
+  <thead>
+    <tr>
+      <th>ID</th>
+      <th>Filename</th>
+      <th>Status</th>
+      <th style="width:140px">Progress</th>
+      <th>Suggested Project</th>
+      <th>Confidence</th>
+      <th>Captured</th>
+      <th>Duration</th>
+      <th>Source</th>
+      <th>Actions</th>
+    </tr>
+  </thead>
+  <tbody>
+    {% for r in recordings_table.rows %}
+    <tr>
+      <td title="{{ r.id }}"><a href="/recordings/{{ r.id }}" style="text-decoration:none;color:#1d4ed8">{{ r.id[:16] }}…</a></td>
+      <td title="{{ r.source_filename }}">{{ r.source_filename }}</td>
+      <td>
+        <span class="badge s-{{ r.status }}">{{ r.status }}</span>
+        {% if r.status_reason_text_display %}
+        <span style="display:block;margin-top:4px;color:#92400e">{{ r.status_reason_text_display }}</span>
+        {% endif %}
+      </td>
+      <td style="max-width:140px">
+        {% if r.status == "Processing" %}
+        {{ r.progress_percent }}% {{ r.progress_stage_label }}
+        {% elif r.status == "Stopping" and r.pipeline_progress is not none %}
+        {{ r.progress_percent }}% {{ r.progress_stage_label }}
+        {% elif r.status == "Stopping" %}
+        Stop requested
+        {% elif r.status == "Queued" %}
+        {{ r.progress_percent }}% {{ r.progress_stage_label }}
+        {% elif r.status in ["Ready", "NeedsReview", "Published"] %}
+        100% Done
+        {% elif r.pipeline_progress is not none %}
+        {{ r.progress_percent }}% {{ r.progress_stage_label }}
+        {% else %}
+        —
+        {% endif %}
+      </td>
+      <td>
+        {% if r.suggested_project_name %}
+        {{ r.suggested_project_name }}
+        {% elif r.suggested_project_id %}
+        #{{ r.suggested_project_id }}
+        {% else %}
+        —
+        {% endif %}
+      </td>
+      <td>
+        {% if r.routing_confidence is not none %}
+        {{ '%.2f'|format(r.routing_confidence) }}
+        {% else %}
+        —
+        {% endif %}
+      </td>
+      <td>{{ r.captured_at_display }}</td>
+      <td>{{ r.duration_display }}</td>
+      <td>{{ r.source }}</td>
+      <td>
+        <select
+          class="action-sel"
+          data-rid="{{ r.id }}"
+          data-rlabel="{{ r.source_filename or r.id }}"
+          data-rcaptured="{{ '' if r.captured_at_display == '—' else r.captured_at_display }}"
+          onchange="doRecAction(this)"
+        >
+          <option value="">Actions</option>
+          <option value="open">Open</option>
+          <option value="requeue">Requeue</option>
+          <option value="quarantine">Quarantine</option>
+          <option value="delete">Delete</option>
+        </select>
+      </td>
+    </tr>
+    {% endfor %}
+  </tbody>
+</table>
+
+<div class="pager">
+  {% if recordings_table.has_prev %}
+  <a href="/recordings?status={{ recordings_table.status_filter }}&limit={{ recordings_table.limit }}&offset={{ recordings_table.prev_offset }}">&#171; Prev</a>
+  {% endif %}
+  <span>{{ recordings_table.offset + 1 }}–{{ [recordings_table.offset + recordings_table.limit, recordings_table.total] | min }} of {{ recordings_table.total }}</span>
+  {% if recordings_table.has_next %}
+  <a href="/recordings?status={{ recordings_table.status_filter }}&limit={{ recordings_table.limit }}&offset={{ recordings_table.next_offset }}">Next &#187;</a>
+  {% endif %}
+</div>
+{% else %}
+<p class="placeholder">No recordings{% if recordings_table.status_filter %} with status <strong>{{ recordings_table.status_filter }}</strong>{% endif %}.</p>
+{% endif %}
