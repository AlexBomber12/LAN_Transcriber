+                candidate_matches_json,
+                needs_review,
+                confidence,
+                created_at
+            )
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (
+                1,
+                1,
+                "rec-db-cov-trusted-sample-migration-1",
+                "S1",
+                "recordings/rec-db-cov-trusted-sample-migration-1/derived/snippets/S1/1.wav",
+                "manual",
+                None,
+                None,
+                None,
+                "[]",
+                0,
+                1.0,
+                "2026-03-01T10:00:00Z",
+            ),
+        )
+        conn.execute(
+            """
+            INSERT INTO voice_samples (
