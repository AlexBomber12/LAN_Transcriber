+        def __call__(self, payload: object, **kwargs: object):
+            self.calls.append((payload, dict(kwargs)))
+
+            class _Annotation:
+                def itertracks(self, yield_label: bool = False):
+                    if yield_label:
+                        yield segment, "S1"
