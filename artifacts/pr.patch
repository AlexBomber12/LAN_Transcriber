+def test_probe_spark_runtime_variants(tmp_path, monkeypatch):
+    unknown = system_status._probe_spark_runtime(_settings(tmp_path, llm_base_url=""))
+    assert unknown["state"] == "unknown"
+
+    seen_headers: list[dict[str, str]] = []
