diff --git a/lan_app/templates/partials/control_center/upload_script.html b/lan_app/templates/partials/control_center/upload_script.html
index 91423e6..1e4ede9 100644
--- a/lan_app/templates/partials/control_center/upload_script.html
+++ b/lan_app/templates/partials/control_center/upload_script.html
@@ -73,6 +73,39 @@ function removePlaceholderRow() {
   }
 }
 
+function restorePlaceholderRow() {
+  var rows = document.getElementById("{{ upload_shell.upload_rows_id }}");
+  if (!rows || rows.querySelector(".upload-queue-item")) {
+    return;
+  }
+  if (document.getElementById("{{ upload_shell.empty_row_id }}")) {
+    return;
+  }
+  var empty = document.createElement("div");
+  empty.id = "{{ upload_shell.empty_row_id }}";
+  empty.className = "upload-queue-empty";
+  empty.textContent = "No active uploads. New files appear here until they enter the main inbox.";
+  rows.appendChild(empty);
+}
+
+function removeUploadItem(item) {
+  if (!item || !item.itemNode || item.removed) {
+    return;
+  }
+  item.removed = true;
+  item.itemNode.remove();
+  restorePlaceholderRow();
+}
+
+function scheduleUploadItemRemoval(item, delayMs) {
+  if (!item || item.removed || item.removalTimer !== null) {
+    return;
+  }
+  item.removalTimer = window.setTimeout(function() {
+    removeUploadItem(item);
+  }, delayMs);
+}
+
 function makeProgressGroup(labelText) {
   var wrap = document.createElement("div");
   wrap.className = "upload-queue-progress-group";
