+        used_dummy_fallback=False,
+        pipeline_settings=cfg,
+        working_audio_path=tmp_path / "audio.wav",
+        step_log_callback=None,
+    )
+    assert merge_map == {}
+    assert diagnostics["skipped_reason"] == "disabled_by_config"
+    assert len(segments) == 2
