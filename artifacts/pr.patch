+{% set speaker_review_compact = speaker_review_mode == 'compact' %}
+{% if rows %}
+<div class="speaker-review-list {% if speaker_review_compact %}speaker-review-list-compact{% else %}speaker-review-list-full{% endif %}">
+  {% for row in rows %}
+  <section class="speaker-card speaker-review-shell {% if speaker_review_compact %}speaker-review-shell-compact{% else %}speaker-review-shell-full{% endif %}">
+    <div class="speaker-card-head">
+      <div class="speaker-card-title">
+        <div class="speaker-avatar">{{ row.speaker }}</div>
+        <div>
+          <div class="speaker-section-label">Diarized speaker</div>
+          <h3>{{ row.display_label }}</h3>
+          <div class="speaker-card-meta" style="margin-top:6px">
+            <span>{{ row.turn_count }} turns</span>
+            <span>{{ '%.2f'|format(row.duration_sec or 0.0) }}s active</span>
+            <span>{{ row.mapping_title }}</span>
+          </div>
+        </div>
+      </div>
+      <div class="speaker-status-stack">
+        <span class="badge {{ row.state_badge_class }}">{{ row.state_badge_label }}</span>
+        {% if row.trusted_sample_state %}
+        <span class="speaker-chip speaker-chip-ready">{{ row.trusted_sample_state.badge_label }}</span>
+        {% endif %}
+      </div>
+    </div>
+
+    <div class="speaker-review-shell-body">
+      <div class="speaker-review-primary">
+        <div class="speaker-context-grid">
+          <section class="embedded-card speaker-context-card">
+            <div class="speaker-section-label">Current decision</div>
+            <p class="speaker-context-title">{{ row.mapping_title }}</p>
+            <p>{{ row.mapping_detail }}</p>
+            <p class="inspector-note" style="margin-top:8px">{{ row.state_detail }}</p>
+            {% if row.review_state == 'system_suggested' %}
+            <p class="inspector-note" style="margin-top:8px">Best suggestion score {{ '%.2f'|format(row.confidence or 0.0) }}</p>
+            {% endif %}
+            {% if row.low_confidence and row.assignment_threshold %}
+            <p class="speaker-warning-inline" style="margin-top:8px">
+              Below auto-match threshold {{ '%.2f'|format(row.assignment_threshold) }}.
+            </p>
+            {% endif %}
+            {% if row.candidate_matches %}
+            <p class="inspector-note" style="margin-top:8px">
+              Suggestions:
+              {% for candidate in row.candidate_matches %}
+              {{ candidate.display_name }} ({{ '%.2f'|format(candidate.score) }}){% if not loop.last %}, {% endif %}
+              {% endfor %}
+            </p>
+            {% endif %}
+          </section>
+
+          <section class="embedded-card speaker-context-card">
+            <div class="speaker-section-label">Recognition cue</div>
+            {% if row.preview_text %}
+            <p class="speaker-cue-text">{{ row.preview_text }}</p>
+            {% else %}
+            <p class="placeholder" style="padding:0">No transcript cue is available for this speaker yet.</p>
+            {% endif %}
+            {% if row.snippet_ui_state %}
+            <p class="inspector-note" style="margin-top:10px;color:{{ row.snippet_ui_state.color }}">
+              <strong>{{ row.snippet_ui_state.label }}:</strong> {{ row.snippet_ui_state.detail }}
+            </p>
+            {% endif %}
+          </section>
+        </div>
+
+        <section class="speaker-snippet-panel">
+          <div class="speaker-snippet-panel-head">
+            <div>
+              <h4>Best snippet candidates</h4>
+              <p class="inspector-note">Use the clearest clip to recognize the voice or save a trusted training sample.</p>
+            </div>
+            {% if row.clean_snippets %}
+            <span class="speaker-chip speaker-chip-ready">{{ row.clean_snippets[:3]|length }} ready</span>
+            {% else %}
+            <span class="speaker-chip speaker-chip-muted">No clean clips</span>
+            {% endif %}
+          </div>
+
+          {% if row.clean_snippets %}
+          <div class="speaker-snippet-grid">
+            {% for snippet in row.clean_snippets[:3] %}
+            <article class="speaker-snippet-card{% if snippet.recommended %} speaker-snippet-card-recommended{% endif %}">
+              <div class="speaker-snippet-card-head">
+                <div class="speaker-card-meta">
+                  {% if snippet.recommended %}
+                  <span class="speaker-chip speaker-chip-ready">Best match</span>
+                  {% else %}
+                  <span class="speaker-chip speaker-chip-muted">Clean clip</span>
+                  {% endif %}
+                  <span>{{ snippet.clip_label }}</span>
+                </div>
+                <span class="speaker-chip speaker-chip-quality">Purity {{ snippet.purity_label }}</span>
+              </div>
+              <p class="speaker-snippet-meta">Source {{ snippet.source_label }}</p>
+              {% if row.preview_text %}
+              <p class="speaker-snippet-cue">Cue: {{ row.preview_text }}</p>
+              {% endif %}
+              <audio controls preload="none" class="speaker-snippet-audio">
+                <source src="{{ snippet.audio_url }}" type="audio/wav">
+              </audio>
+              <p class="speaker-snippet-choice">{{ snippet.choice_label }}</p>
+            </article>
+            {% endfor %}
+          </div>
+          {% else %}
+          <div class="speaker-snippet-empty">
+            <p class="speaker-snippet-empty-title">{{ row.snippet_ui_state.label if row.snippet_ui_state else 'Snippets unavailable' }}</p>
+            <p>{{ row.snippet_ui_state.detail if row.snippet_ui_state else (row.no_clean_snippet_message or 'No clean snippets are available for this speaker yet.') }}</p>
+            {% if row.no_clean_snippet_message and row.snippet_ui_state and row.no_clean_snippet_message != row.snippet_ui_state.detail %}
+            <p class="inspector-note" style="margin-top:8px">{{ row.no_clean_snippet_message }}</p>
+            {% endif %}
+          </div>
+          {% endif %}
+
+          {% if row.snippet_warnings %}
+          <div class="speaker-warning-list">
+            {% for warning in row.snippet_warnings %}
+            <p class="speaker-warning">{{ warning }}</p>
+            {% endfor %}
+          </div>
+          {% endif %}
+        </section>
+      </div>
+
+      <div class="speaker-action-stack">
+        <section class="speaker-decision-card speaker-decision-card-primary">
+          <div class="speaker-action-head">
+            <div>
+              <h3>Confirm match</h3>
+              <p class="inspector-note">Assign a canonical identity across recordings.</p>
+            </div>
+          </div>
+          {% if profiles %}
+          <form method="post" action="/ui/recordings/{{ rec.id }}/speakers/assign{{ recording_inspector.embedded_return_queries.speakers }}" class="speaker-form-stack">
+            <input type="hidden" name="diar_speaker_label" value="{{ row.speaker }}">
+            <div class="filter-field">
+              <label for="speaker-match-{{ rec.id }}-{{ row.speaker }}">Canonical speaker</label>
+              <select id="speaker-match-{{ rec.id }}-{{ row.speaker }}" name="voice_profile_id">
+                <option value="">Choose canonical speaker</option>
+                {% for vp in profiles %}
+                <option value="{{ vp.id }}" {% if row.global_voice_profile_id == vp.id %}selected{% endif %}>{{ vp.display_name }}</option>
+                {% endfor %}
+              </select>
+            </div>
+            <button class="btn speaker-action-submit speaker-action-submit-primary" type="submit">Confirm match</button>
+          </form>
+          {% else %}
+          <p class="placeholder" style="padding:0">
+            No canonical speakers exist yet. {% if speaker_review_compact %}Use the full-page inspector or Voices to create one first.{% else %}Use Voices to create one first.{% endif %}
+          </p>
+          {% endif %}
+        </section>
+
+        <section class="speaker-decision-card">
+          <div class="speaker-action-head">
+            <div>
+              <h3>Keep unknown</h3>
+              <p class="inspector-note">Resolve review without naming the speaker or changing the global speaker bank.</p>
+            </div>
+          </div>
+          <form method="post" action="/ui/recordings/{{ rec.id }}/speakers/keep-unknown{{ recording_inspector.embedded_return_queries.speakers }}" class="speaker-form-stack">
+            <input type="hidden" name="diar_speaker_label" value="{{ row.speaker }}">
+            <button class="btn speaker-action-submit" type="submit">Keep unknown</button>
+          </form>
+        </section>
+
+        <section class="speaker-decision-card">
+          <div class="speaker-action-head">
+            <div>
+              <h3>Local label only</h3>
+              <p class="inspector-note">Name this speaker only inside this recording and its export.</p>
+            </div>
+          </div>
+          <form method="post" action="/ui/recordings/{{ rec.id }}/speakers/local-label{{ recording_inspector.embedded_return_queries.speakers }}" class="speaker-form-stack">
+            <input type="hidden" name="diar_speaker_label" value="{{ row.speaker }}">
+            <div class="filter-field">
+              <label for="speaker-local-{{ rec.id }}-{{ row.speaker }}">Recording-only name</label>
+              <input
+                id="speaker-local-{{ rec.id }}-{{ row.speaker }}"
+                type="text"
+                name="local_display_name"
+                value="{{ row.local_display_name }}"
+                maxlength="120"
+                placeholder="Recording-only name"
+              >
+            </div>
+            <button class="btn speaker-action-submit" type="submit">Local label only</button>
+          </form>
+        </section>
+
+        <section class="speaker-decision-card speaker-decision-card-secondary">
+          <div class="speaker-action-head">
+            <div>
+              <div class="speaker-section-label">Training only</div>
+              <h3>Add trusted sample</h3>
+              <p class="inspector-note">Store a clean clip as training data without changing the current review decision.</p>
+            </div>
+          </div>
+
+          {% if row.trusted_sample_state %}
+          <div class="speaker-trusted-sample-state">
+            <div class="speaker-status-stack">
+              <span class="badge s-Ready">{{ row.trusted_sample_state.badge_label }}</span>
+              <span>{{ row.trusted_sample_state.detail }}</span>
+            </div>
+          </div>
+          {% endif %}
+
+          {% if profiles %}
+          <form method="post" action="/ui/recordings/{{ rec.id }}/speakers/add-sample{{ recording_inspector.embedded_return_queries.speakers }}" class="speaker-form-stack">
+            <input type="hidden" name="diar_speaker_label" value="{{ row.speaker }}">
+            <div class="filter-field">
+              <label for="speaker-sample-profile-{{ rec.id }}-{{ row.speaker }}">Canonical speaker</label>
+              <select id="speaker-sample-profile-{{ rec.id }}-{{ row.speaker }}" name="voice_profile_id">
+                <option value="">Choose canonical speaker</option>
+                {% for vp in profiles %}
+                <option value="{{ vp.id }}" {% if row.sample_voice_profile_id == vp.id %}selected{% endif %}>{{ vp.display_name }}</option>
+                {% endfor %}
+              </select>
+            </div>
+            <div class="filter-field">
+              <label for="speaker-sample-snippet-{{ rec.id }}-{{ row.speaker }}">Snippet choice</label>
+              <select id="speaker-sample-snippet-{{ rec.id }}-{{ row.speaker }}" name="snippet_path" {% if not row.clean_snippets %}disabled{% endif %}>
+                {% for snippet in row.clean_snippets[:3] %}
+                <option value="{{ snippet.relative_path }}" {% if snippet.recommended %}selected{% endif %}>{{ snippet.choice_label }}</option>
+                {% endfor %}
+              </select>
+            </div>
+            <button class="btn speaker-action-submit" type="submit" {% if not row.clean_snippets %}disabled{% endif %}>Add trusted sample</button>
+          </form>
+          {% else %}
+          <p class="placeholder" style="padding:0">Create a canonical speaker first, then add trusted samples from clean clips.</p>
+          {% endif %}
+
+          {% if not row.clean_snippets and row.snippet_ui_state and row.snippet_ui_state.add_sample_message %}
+          <p class="speaker-warning-inline" style="margin-top:8px">{{ row.snippet_ui_state.add_sample_message }}</p>
+          {% elif row.no_clean_snippet_message %}
+          <p class="speaker-warning-inline" style="margin-top:8px">{{ row.no_clean_snippet_message }}</p>
+          {% endif %}
+        </section>
+      </div>
+    </div>
+  </section>
+  {% endfor %}
+</div>
+{% else %}
+<p class="placeholder">No speaker turns available yet. Run diarization first.</p>
+{% endif %}
