+
+def _write_existing_manifest(cfg: AppSettings, recording_id: str) -> tuple[Path, Path]:
+    derived = cfg.recordings_root / recording_id / "derived"
+    snippets = derived / "snippets" / "S1"
+    snippets.mkdir(parents=True, exist_ok=True)
