+        <td style="white-space:normal;max-width:220px">
+          {% if row.low_confidence %}
+          <span class="badge s-NeedsReview">Low confidence</span>
+          {% elif row.voice_profile_name %}
+          <span class="badge s-Ready">Mapped</span>
+          {% else %}
+          <span class="badge s-Queued">Unmatched</span>
+          {% endif %}
+          <div style="margin-top:4px;color:#555">{{ '%.2f'|format(row.confidence or 0.0) }}</div>
