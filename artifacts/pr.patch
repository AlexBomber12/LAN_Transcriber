+            {
+                "chunk_index": "3a",
+                "chunk_total": 6,
+                "status": "completed",
+                "attempt": 1,
+                "updated_at": "2026-03-12T12:00:04Z",
+            },
+        ],
+        jobs=[],
+        now=datetime(2026, 3, 12, 12, 0, 5, tzinfo=timezone.utc),
+    )
+
+    assert diagnostics_payload["primary_reason_code"] is None
