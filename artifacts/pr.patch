+    if status == RECORDING_STATUS_PUBLISHED:
+        return "Published output is available."
+    if status == RECORDING_STATUS_QUARANTINE:
+        return "Quarantined. Inspect before requeue."
+    if status == RECORDING_STATUS_FAILED:
