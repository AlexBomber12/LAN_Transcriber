+def test_weak_and_suspicious_capture_time_trigger_conservative_behavior(tmp_path: Path) -> None:
+    cfg = _cfg(tmp_path)
+    init_db(cfg)
+    source = create_calendar_source(
+        name="Team Calendar",
+        kind="file",
