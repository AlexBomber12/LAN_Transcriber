@@ -0,0 +1,19 @@
+{% include "partials/recording_inspector_header.html" %}
+
+{% if rec.status in ['Processing', 'Stopping'] %}
+<div
+  id="recording-progress"
+  hx-get="{{ recording_inspector.progress_url }}"
+  hx-trigger="load, every 2s"
+  hx-swap="innerHTML"
+  style="margin:0 0 10px 0"
+>
+  <div class="placeholder" style="padding:8px 10px">Loading pipeline progress…</div>
+</div>
+{% endif %}
+
+{% include "partials/recording_inspector_tabs.html" %}
+
+<div class="tab-content">
+  {% include "partials/recording_inspector_body.html" %}
+</div>
diff --git a/lan_app/templates/partials/recording_inspector_body.html b/lan_app/templates/partials/recording_inspector_body.html
new file mode 100644
index 0000000..6d2b746
--- /dev/null
+++ b/lan_app/templates/partials/recording_inspector_body.html
@@ -0,0 +1,819 @@
+{% if current_tab == 'overview' %}
+  {% set summary_data = summary or {} %}
+  {% set glossary_data = glossary or {} %}
+  <div class="section" style="margin-bottom:10px">
+    <h2 style="margin-top:0">Diagnostics</h2>
+    <div class="info-grid">
+      <span class="k">Primary reason</span><span class="v">{{ diagnostics.primary_reason_text or '—' }}</span>
+      <span class="k">Reason code</span><span class="v">{{ diagnostics.primary_reason_code or '—' }}</span>
+      <span class="k">Current / last stage</span><span class="v">{{ diagnostics.current_stage_label or '—' }}</span>
+      <span class="k">Stage status</span><span class="v">{{ diagnostics.current_stage_status_label or '—' }}</span>
+      <span class="k">Chunk</span><span class="v">{{ diagnostics.chunk_text or '—' }}</span>
+      <span class="k">Stage attempt</span><span class="v">{{ diagnostics.stage_attempt_text or '—' }}</span>
+      <span class="k">Chunk attempt</span><span class="v">{{ diagnostics.chunk_attempt_text or '—' }}</span>
+      <span class="k">Stage elapsed</span><span class="v">{{ diagnostics.stage_elapsed_display or '—' }}</span>
+      <span class="k">Chunk elapsed</span><span class="v">{{ diagnostics.chunk_elapsed_display or '—' }}</span>
+      <span class="k">Stop mode</span><span class="v">{{ diagnostics.stop_mode or '—' }}</span>
+      <span class="k">Retry wrapper</span><span class="v">{{ diagnostics.wrapper_reason_text or '—' }}</span>
+      <span class="k">Reason detail</span><span class="v">{{ diagnostics.primary_reason_detail or diagnostics.stop_reason_text or '—' }}</span>
+    </div>
+  </div>
+  <div class="info-grid">
+    <span class="k">ID</span><span class="v">{{ rec.id }}</span>
+    <span class="k">Filename</span><span class="v">{{ rec.source_filename }}</span>
+    <span class="k">Source</span><span class="v">{{ rec.source }}</span>
+    <span class="k">Status</span>
+    <span class="v">
+      <span class="badge s-{{ rec.status }}">{{ rec.status }}</span>
+      {% if rec.status_reason_text_display %}
+      <span style="color:#92400e">{{ rec.status_reason_text_display }}</span>
+      {% endif %}
+    </span>
+    <span class="k">Captured at</span><span class="v">{{ rec.captured_at_display }}</span>
+    <span class="k">Duration</span><span class="v">{{ rec.duration_display }}</span>
+    <span class="k">Project</span><span class="v">{{ rec.project_name or (rec.project_id and ('#' ~ rec.project_id)) or '—' }}</span>
+    <span class="k">Suggested project</span><span class="v">{{ rec.suggested_project_name or (rec.suggested_project_id and ('#' ~ rec.suggested_project_id)) or '—' }}</span>
+    <span class="k">Routing confidence</span>
+    <span class="v">
+      {% if rec.routing_confidence is not none %}
+      {{ '%.2f'|format(rec.routing_confidence) }}
+      {% else %}
+      —
+      {% endif %}
+    </span>
+    <span class="k">Language (auto)</span><span class="v">{{ rec.language_auto or '—' }}</span>
+    <span class="k">Transcript language override</span><span class="v">{{ rec.language_override or '—' }}</span>
+    <span class="k">Target summary language</span><span class="v">{{ rec.target_summary_language or '—' }}</span>
+    <span class="k">Drive file ID</span><span class="v">{{ rec.drive_file_id or '—' }}</span>
+    <span class="k">Quarantine reason</span><span class="v">{{ rec.quarantine_reason or '—' }}</span>
+    <span class="k">Review reason</span><span class="v">{{ rec.review_reason_text_display or '—' }}</span>
+    <span class="k">Stop requested</span>
+    <span class="v">
+      {% if rec.cancel_requested_at_display != '—' %}
+      {{ rec.cancel_requested_at_display }}{% if rec.cancel_requested_by_display %} by {{ rec.cancel_requested_by_display }}{% endif %}
+      {% else %}
+      —
+      {% endif %}
+    </span>
+    <span class="k">Stop reason</span><span class="v">{{ rec.cancel_reason_text_display or '—' }}</span>
+    <span class="k">Created at</span><span class="v">{{ rec.created_at_display }}</span>
+    <span class="k">Updated at</span><span class="v">{{ rec.updated_at_display }}</span>
+  </div>
+
+  {% if pipeline_stages %}
+  <div class="section" style="margin-top:10px">
+    <h2 style="margin-top:0">Pipeline Stages</h2>
+    <table>
+      <thead>
+        <tr>
+          <th>Stage</th>
+          <th>Status</th>
+          <th>Attempt</th>
+          <th>Updated</th>
+          <th>Notes</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for stage in pipeline_stages %}
+        <tr>
+          <td>{{ stage.stage_label }}</td>
+          <td>{{ stage.status_label }}</td>
+          <td>{{ stage.attempt }}</td>
+          <td>{{ stage.updated_at_display }}</td>
+          <td>
+            {% if stage.root_cause_text %}
+            {{ stage.root_cause_text }}{% if stage.root_cause_code %} (<code>{{ stage.root_cause_code }}</code>){% endif %}
+            {% if stage.chunk_index and stage.chunk_total %}
+            &nbsp;chunk {{ stage.chunk_index }}/{{ stage.chunk_total }}
+            {% endif %}
+            {% if stage.stop_mode %}
+            &nbsp;mode={{ stage.stop_mode }}
+            {% endif %}
+            {% elif stage.error_text %}
+            {{ stage.error_text }}
+            {% elif stage.duration_seconds is not none %}
+            {{ '%.3f'|format(stage.duration_seconds) }}s
+            {% else %}
+            —
+            {% endif %}
+          </td>
+        </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+  {% endif %}
+
+  <div class="section" style="margin-top:10px">
+    <h2 style="margin-top:0">Export</h2>
+    <div class="filters" style="margin-bottom:6px">
+      <button type="button" class="btn" onclick="copyExportText()">Copy</button>
+      <a
+        href="/ui/recordings/{{ rec.id }}/export.zip"
+        class="btn"
+        style="text-decoration:none"
+        hx-boost="false"
+      >Download ZIP</a>
+    </div>
+    <textarea
+      id="export-text"
+      readonly
+      style="width:100%;min-height:220px;resize:vertical"
+    >{{ export_text or '' }}</textarea>
+    <p id="export-copy-status" class="placeholder" style="padding:6px 0 0 0">
+      Copy the markdown or download a ZIP with the available artifacts.
+    </p>
+  </div>
+
+  <script>
+  function copyExportText() {
+    var textarea = document.getElementById('export-text');
+    var status = document.getElementById('export-copy-status');
+    if (!textarea) return;
+    var setStatus = function(msg) {
+      if (status) status.textContent = msg;
+    };
+    var fallback = function() {
+      textarea.focus();
+      textarea.select();
+      try {
+        document.execCommand('copy');
+        setStatus('Copied export markdown.');
+      } catch (_err) {
+        setStatus('Copy failed. Select the text and copy manually.');
+      }
+    };
+    if (navigator.clipboard && navigator.clipboard.writeText) {
+      navigator.clipboard.writeText(textarea.value).then(
+        function() { setStatus('Copied export markdown.'); },
+        fallback
+      );
+      return;
+    }
+    fallback();
+  }
+  </script>
+
+  <h2>Topic</h2>
+  <p>{{ summary_data.topic or '—' }}</p>
+
+  <h2>Summary</h2>
+  {% if summary_data.summary_bullets %}
+  <ul>
+    {% for bullet in summary_data.summary_bullets %}
+    <li>{{ bullet }}</li>
+    {% endfor %}
+  </ul>
+  {% elif summary_data.summary_text %}
