+      <thead>
+        <tr>
+          <th>Event</th>
+          <th>When</th>
+          <th>Source</th>
+          <th>Confidence</th>
+          <th>Attendees</th>
+          <th>Rationale</th>
+          <th>Action</th>
+        </tr>
+      </thead>
