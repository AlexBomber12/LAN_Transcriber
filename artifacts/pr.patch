+def test_ffprobe_and_speech_ratio_error_branches(tmp_path: Path, monkeypatch: pytest.MonkeyPatch) -> None:
+    audio = _audio_file(tmp_path, "a.wav")
+    monkeypatch.setattr(precheck.shutil, "which", lambda _name: "/usr/bin/tool")
