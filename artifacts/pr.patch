+.control-center-empty-state strong{
+  font-size:1rem;
+  font-style:normal;
+  color:var(--text);
+}
+.control-center-compact-card{
+  border:1px solid var(--line);
+  background:var(--panel-soft);
+  border-radius:18px;
+  padding:16px;
+}
+.control-center-compact-grid{
+  display:grid;
+  gap:10px;
+  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
+}
+.control-center-upload-card{
+  display:grid;
+  gap:16px;
+  padding:18px;
+  background:linear-gradient(180deg, #fff 0%, #f9fbff 100%);
+  border:1px solid var(--line);
+  border-radius:22px;
+  box-shadow:var(--shadow-soft);
+}
+.control-center-upload-grid{
+  display:grid;
+  gap:14px;
+  grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr);
+}
+.control-center-upload-dropzone{
+  display:grid;
+  gap:10px;
+  justify-items:start;
+  padding:20px;
+  border-radius:22px;
+  border:2px dashed #b6c8ea;
+  background:
+    linear-gradient(180deg, rgba(255,255,255,.92) 0%, rgba(240,245,255,.96) 100%);
+  color:var(--muted);
+  user-select:none;
+  transition:border-color .16s ease,transform .16s ease,background .16s ease;
+}
+.control-center-upload-dropzone:hover,
+.control-center-upload-dropzone:focus{
+  border-color:#84a9f8;
+  background:#f7faff;
+  transform:translateY(-1px);
+}
+.upload-caption{
+  font-size:12px;
+  color:var(--muted);
+}
+.upload-queue-shell{
+  display:grid;
+  gap:12px;
+  align-content:start;
+}
+.upload-queue-table table{margin:0}
+.upload-progress-wrap{
+  display:flex;
+  align-items:center;
+  gap:8px;
+  min-width:140px;
+}
+.upload-progress-track{
+  width:92px;
+  height:8px;
+  border-radius:999px;
+  background:#e8eef7;
+  overflow:hidden;
+}
+.upload-progress-fill{
+  height:100%;
+  width:0;
+  border-radius:999px;
+  background:linear-gradient(90deg, #2463eb 0%, #5b8dff 100%);
+}
+.upload-progress-label{
+  font-size:11px;
+  font-weight:700;
+  color:var(--muted);
+}
+.upload-progress-pill{
+  display:inline-flex;
+  align-items:center;
+  gap:6px;
+  padding:5px 10px;
+  border-radius:999px;
+  background:var(--primary-soft);
+  color:var(--primary);
+  font-size:11px;
+  font-weight:800;
+  letter-spacing:.08em;
+}
+.recordings-panel{
+  display:grid;
+  gap:14px;
+}
+.recordings-panel-frame{
+  border:1px solid var(--line);
+  border-radius:22px;
+  background:linear-gradient(180deg, #fff 0%, #f9fbff 100%);
+  padding:18px;
+  box-shadow:var(--shadow-soft);
+}
+.recordings-filter-strip{
+  display:grid;
+  gap:10px;
+}
+.recordings-filter-strip .filters{align-items:flex-end}
+.filter-field{
+  display:grid;
+  gap:6px;
+  min-width:0;
+}
+.filter-field-grow{flex:1 1 240px}
+.recordings-table-wrap{overflow:auto}
+.recordings-table{
+  min-width:820px;
+}
+.recording-row-selected{background:#f1f6ff}
+.recording-main{
+  display:grid;
+  gap:6px;
+}
+.recording-name{
+  font-weight:700;
+  color:var(--text);
+  text-decoration:none;
+}
+.recording-meta{
+  display:flex;
+  gap:8px;
+  flex-wrap:wrap;
+  font-size:12px;
+  color:var(--muted);
+}
+.recording-progress{
+  display:grid;
+  gap:6px;
+}
+.progress-track{
+  height:7px;
+  border-radius:999px;
+  background:#e8eef7;
+  overflow:hidden;
+}
+.progress-fill{
+  height:100%;
+  border-radius:999px;
+  background:linear-gradient(90deg, #2463eb 0%, #5b8dff 100%);
+}
+.recording-selected-flag{
+  display:inline-flex;
+  align-items:center;
+  gap:6px;
+  font-size:11px;
+  font-weight:800;
+  color:var(--primary);
+  text-transform:uppercase;
+  letter-spacing:.08em;
+}
+.recording-selected-flag::before{
+  content:"";
+  width:8px;
+  height:8px;
+  border-radius:50%;
+  background:var(--primary);
+}
+.recording-reason{
+  display:block;
+  margin-top:6px;
+  color:var(--warning);
+  white-space:normal;
+}
+.inspector-shell{
+  display:grid;
+  gap:16px;
+}
+.inspector-shell-full{
+  background:transparent;
+}
+.inspector-hero,
+.inspector-section-card{
+  background:var(--panel);
+  border:1px solid var(--line);
+  border-radius:24px;
+  box-shadow:var(--shadow);
+}
+.inspector-hero{
+  padding:22px;
+  display:grid;
+  gap:16px;
+}
+.inspector-hero.embedded{
+  padding:18px;
+  gap:14px;
+  box-shadow:none;
+}
+.inspector-heading{
+  display:flex;
+  justify-content:space-between;
+  gap:18px;
+  align-items:flex-start;
+  flex-wrap:wrap;
+}
+.inspector-title-block{
+  display:grid;
+  gap:8px;
+}
+.inspector-title-block h2,
+.inspector-title-block h1{
+  max-width:18ch;
+  overflow-wrap:anywhere;
+}
+.inspector-subtitle{
+  color:var(--muted);
+  font-size:13px;
+}
+.inspector-meta-grid{
+  display:flex;
+  flex-wrap:wrap;
+  gap:8px;
+}
+.inspector-meta-chip{
+  display:inline-flex;
+  align-items:center;
+  gap:6px;
+  padding:7px 10px;
+  border-radius:999px;
+  border:1px solid var(--line);
+  background:var(--panel-soft);
+  color:var(--muted);
+  font-size:12px;
+  font-weight:700;
+}
+.inspector-action-bar{
+  display:flex;
+  gap:8px;
+  flex-wrap:wrap;
+  align-items:center;
+}
+.inspector-progress-shell{
+  padding:14px 16px;
+  border-radius:18px;
+  border:1px solid #dbe5f6;
+  background:#f7faff;
+}
+.inspector-tab-shell{
+  display:grid;
+  gap:14px;
+}
+.embedded-panel-grid,
+.review-card-grid,
+.metric-card-grid{
+  display:grid;
+  gap:14px;
+  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
+}
+.review-card,
+.metric-card,
+.embedded-card,
+.speaker-decision-card{
+  border:1px solid var(--line);
+  border-radius:18px;
+  background:var(--panel-soft);
+  padding:16px;
+}
+.review-card h3,
+.metric-card h3,
+.embedded-card h3,
+.speaker-decision-card h3{margin-bottom:10px}
+.speaker-review-list{
+  display:grid;
+  gap:14px;
+}
+.speaker-card{
+  border:1px solid var(--line);
+  border-radius:20px;
+  background:var(--panel);
+  padding:16px;
+  display:grid;
+  gap:14px;
+  box-shadow:var(--shadow-soft);
+}
+.speaker-card-head{
+  display:flex;
+  justify-content:space-between;
+  gap:10px;
+  align-items:flex-start;
+  flex-wrap:wrap;
+}
+.speaker-card-title{
+  display:flex;
+  gap:10px;
+  align-items:center;
+}
+.speaker-avatar{
+  display:grid;
+  place-items:center;
+  width:38px;
+  height:38px;
+  border-radius:14px;
+  background:var(--primary-soft);
+  color:var(--primary);
+  font-weight:800;
+}
+.speaker-card-meta{
+  display:flex;
+  gap:8px;
+  flex-wrap:wrap;
+  color:var(--muted);
+  font-size:12px;
+}
+.speaker-actions-grid{
+  display:grid;
+  gap:12px;
+  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
+}
+.speaker-audio-list{
+  display:grid;
+  gap:10px;
+}
+.speaker-audio-clip{
+  border:1px solid var(--line);
+  border-radius:14px;
+  background:#fff;
+  padding:12px;
+}
+.speaker-note,
+.inspector-note{
+  color:var(--muted);
+  font-size:12px;
+}
+.page-notice{
+  border:1px solid #dbe5f6;
+  background:#f7faff;
+  color:var(--text);
+  border-radius:16px;
+  padding:12px 14px;
+}
+.detail-page-shell{
+  display:grid;
+  gap:20px;
+}
+@media (max-width: 1180px){
   .control-center-main{grid-template-columns:1fr}
 }
+@media (max-width: 860px){
+  .app-nav{align-items:flex-start;flex-direction:column}
+  .app-nav-links{width:100%}
+  .control-center-hero{padding:20px;flex-direction:column}
+  .control-center-toolbar{justify-items:start}
+  .control-center-toolbar-actions{justify-content:flex-start}
+  .control-center-upload-grid{grid-template-columns:1fr}
+  .filters{flex-direction:column;align-items:stretch}
+  .filter-field,.filter-field-grow{width:100%}
+  .form-row{align-items:stretch}
+  .form-row label{min-width:0}
+  .inspector-heading{flex-direction:column}
+  .tabs{overflow:auto;flex-wrap:nowrap;padding-bottom:10px}
+}
 </style>
 </head>
