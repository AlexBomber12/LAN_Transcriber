   padding:12px;
 }
+.speaker-section-label{
+  color:var(--muted);
+  font-size:11px;
+  font-weight:700;
+  letter-spacing:.06em;
+  text-transform:uppercase;
+}
+.speaker-review-shell{
+  gap:16px;
+}
+.speaker-review-shell-full .speaker-review-shell-body{
+  display:grid;
+  gap:14px;
+  grid-template-columns:minmax(0,1.45fr) minmax(280px,.95fr);
+  align-items:start;
+}
+.speaker-review-shell-compact .speaker-review-shell-body{
+  display:grid;
+  gap:14px;
+}
+.speaker-review-primary{
+  display:grid;
+  gap:12px;
+}
+.speaker-context-grid{
+  display:grid;
+  gap:12px;
+  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
+}
+.speaker-context-card{
+  display:grid;
+  gap:8px;
+}
+.speaker-context-title{
+  margin:0;
+  font-size:1.05rem;
+  font-weight:800;
+  color:var(--text);
+}
+.speaker-card-title h3{
+  margin:0;
+}
+.speaker-status-stack{
+  display:flex;
+  gap:8px;
+  flex-wrap:wrap;
+  align-items:center;
+}
+.speaker-cue-text{
+  margin:0;
+  padding:10px 12px;
+  border-radius:14px;
+  background:#fff;
+  border:1px solid var(--line);
+  color:var(--text);
+  font-size:13px;
+  line-height:1.55;
+}
+.speaker-snippet-panel{
+  border:1px solid var(--line);
+  border-radius:18px;
+  background:var(--panel-soft);
+  padding:16px;
+  display:grid;
+  gap:12px;
+}
+.speaker-snippet-panel h4{
+  margin:0 0 4px 0;
+  font-size:1rem;
+}
+.speaker-snippet-panel-head{
+  display:flex;
+  justify-content:space-between;
+  gap:12px;
+  align-items:flex-start;
+  flex-wrap:wrap;
+}
+.speaker-snippet-grid{
+  display:grid;
+  gap:12px;
+  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
+}
+.speaker-review-shell-compact .speaker-snippet-grid{
+  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
+}
+.speaker-snippet-card{
+  border:1px solid var(--line);
+  border-radius:16px;
+  background:#fff;
+  padding:12px;
+  display:grid;
+  gap:10px;
+}
+.speaker-snippet-card-recommended{
+  border-color:#bfd5ff;
+  box-shadow:0 0 0 1px #dbeafe inset;
+}
+.speaker-snippet-card-head,
+.speaker-action-head{
+  display:flex;
+  justify-content:space-between;
+  gap:10px;
+  align-items:flex-start;
+  flex-wrap:wrap;
+}
+.speaker-chip{
+  display:inline-flex;
+  align-items:center;
+  gap:6px;
+  min-height:24px;
+  padding:4px 10px;
+  border-radius:999px;
+  border:1px solid var(--line);
+  background:#fff;
+  color:var(--text);
+  font-size:11px;
+  font-weight:700;
+}
+.speaker-chip-ready{
+  border-color:#bfdbfe;
+  background:#eff6ff;
+  color:var(--primary);
+}
+.speaker-chip-quality{
+  border-color:#dbeafe;
+  background:#eef4ff;
+  color:#1d4ed8;
+}
+.speaker-chip-muted{
+  color:var(--muted);
+}
+.speaker-snippet-meta,
+.speaker-snippet-choice{
+  margin:0;
+  color:var(--muted);
+  font-size:12px;
+}
+.speaker-snippet-cue{
+  margin:0;
+  padding:10px 12px;
+  border-radius:14px;
+  background:#f8fbff;
+  color:var(--text);
+  font-size:13px;
+  line-height:1.5;
+}
+.speaker-snippet-audio{
+  width:100%;
+  min-width:0;
+}
+.speaker-snippet-empty{
+  border:1px dashed var(--line-strong);
+  border-radius:16px;
+  background:#fff;
+  padding:14px;
+}
+.speaker-snippet-empty-title{
+  margin:0 0 6px 0;
+  font-size:13px;
+  font-weight:800;
+  color:var(--text);
+}
+.speaker-warning-list{
+  display:grid;
+  gap:6px;
+}
+.speaker-warning,
+.speaker-warning-inline{
+  margin:0;
+  color:#92400e;
+  font-size:12px;
+}
+.speaker-action-stack{
+  display:grid;
+  gap:12px;
+}
+.speaker-review-shell-full .speaker-action-stack{
+  grid-template-columns:1fr;
+}
+.speaker-review-shell-compact .speaker-action-stack{
+  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
+}
+.speaker-decision-card-primary{
+  background:#f7faff;
+}
+.speaker-decision-card-secondary{
+  border-style:dashed;
+  background:#fffdf5;
+}
+.speaker-form-stack{
+  display:grid;
+  gap:10px;
+}
+.speaker-form-stack select,
+.speaker-form-stack input{
+  width:100%;
+}
+.speaker-action-submit{
+  width:100%;
+}
+.speaker-action-submit-primary{
+  border-color:#bfd5ff;
+  background:#eff6ff;
+  color:var(--primary);
+}
+.speaker-trusted-sample-state{
+  margin-bottom:10px;
+  padding:10px 12px;
+  border:1px solid var(--line);
+  border-radius:14px;
+  background:#fff;
+}
 .speaker-note,
 .inspector-note{
   color:var(--muted);
@@ -1295,6 +1507,11 @@ textarea:focus{
   .form-row label{min-width:0}
   .inspector-heading{flex-direction:column}
   .tabs{overflow:auto;flex-wrap:nowrap;padding-bottom:10px}
+  .speaker-review-shell-full .speaker-review-shell-body,
+  .speaker-review-shell-compact .speaker-action-stack,
+  .speaker-context-grid,
+  .speaker-snippet-grid{grid-template-columns:1fr}
+  .speaker-card-title{align-items:flex-start}
 }
 </style>
 </head>
