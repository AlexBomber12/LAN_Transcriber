+def _elf64_header(*, e_phoff: int, e_phentsize: int, e_phnum: int) -> bytes:
+    return struct.pack(
+        "<HHIQQQIHHHHHH",
+        2,
+        62,
+        1,
+        0,
+        e_phoff,
+        0,
+        0,
+        64,
+        e_phentsize,
+        e_phnum,
+        0,
+        0,
+        0,
+    )
+
