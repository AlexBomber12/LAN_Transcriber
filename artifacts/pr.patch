@@ -0,0 +1,49 @@
+{% if pipeline_stages %}
+<div class="space-y-0">
+  {% for stage in pipeline_stages %}
+  <div class="flex gap-3">
+    <div class="flex flex-col items-center">
+      {% if stage.status == 'completed' or stage.status == 'skipped' %}
+      <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
+      {% if not loop.last %}<div class="w-0.5 h-full bg-green-500/30 my-1"></div>{% endif %}
+      {% elif stage.status == 'running' %}
+      <div class="size-5 rounded-full border-2 border-primary border-t-transparent animate-spin my-0.5"></div>
+      {% if not loop.last %}<div class="w-0.5 h-full bg-slate-200 my-1"></div>{% endif %}
+      {% elif stage.status == 'failed' %}
+      <span class="material-symbols-outlined text-red-500 text-lg">error</span>
+      {% if not loop.last %}<div class="w-0.5 h-full bg-red-500/30 my-1"></div>{% endif %}
+      {% elif stage.status == 'cancelled' %}
+      <span class="material-symbols-outlined text-slate-400 text-lg">cancel</span>
+      {% if not loop.last %}<div class="w-0.5 h-full bg-slate-200 my-1"></div>{% endif %}
+      {% else %}
+      <span class="material-symbols-outlined text-slate-300 text-lg">circle</span>
+      {% if not loop.last %}<div class="w-0.5 h-full bg-slate-200 my-1"></div>{% endif %}
+      {% endif %}
+    </div>
+    <div class="flex-1 {% if not loop.last %}pb-4{% endif %}">
+      <div class="flex justify-between items-start mb-1">
+        <p class="text-sm font-semibold {% if stage.status == 'pending' %}text-slate-400{% else %}text-slate-900{% endif %}">{{ stage.stage_label }}</p>
+        <span class="text-[10px] {% if stage.status == 'running' %}text-primary{% elif stage.status == 'failed' %}text-red-500{% else %}text-slate-400{% endif %}">
+          {% if stage.status == 'running' %}In progress{% elif stage.duration_seconds is not none %}{{ '%.1f'|format(stage.duration_seconds) }}s{% else %}{{ stage.status_label }}{% endif %}
+        </span>
+      </div>
+      {% if stage.status == 'running' %}
+      <div class="w-full bg-slate-100 rounded-full h-1.5 mt-2 overflow-hidden">
+        <div class="bg-primary h-full animate-pulse" style="width: 65%;"></div>
+      </div>
+      {% elif stage.root_cause_text %}
+      <p class="text-xs text-slate-500">{{ stage.root_cause_text }}{% if stage.root_cause_code %} ({{ stage.root_cause_code }}){% endif %}</p>
+      {% elif stage.error_text %}
+      <p class="text-xs text-red-500">{{ stage.error_text }}</p>
+      {% elif stage.duration_seconds is not none %}
+      <p class="text-xs text-slate-500">Completed in {{ '%.3f'|format(stage.duration_seconds) }}s</p>
+      {% elif stage.status == 'pending' %}
+      <p class="text-xs text-slate-500 italic">Queued</p>
+      {% endif %}
+    </div>
+  </div>
+  {% endfor %}
+</div>
+{% else %}
+<p class="text-sm text-slate-400 italic">No pipeline stage history is available for this recording yet.</p>
+{% endif %}
diff --git a/lan_app/templates/partials/speaker_review_table.html b/lan_app/templates/partials/speaker_review_table.html
new file mode 100644
index 0000000..6f93bb1
--- /dev/null
+++ b/lan_app/templates/partials/speaker_review_table.html
@@ -0,0 +1,181 @@
+{% from "partials/macros.html" import status_badge_classes %}
+{% if rows %}
+<div class="overflow-x-auto" data-testid="speaker-review-table">
+  <table class="w-full text-sm">
+    <thead>
+      <tr class="text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-200">
+        <th class="text-left py-2 px-3">Speaker ID</th>
+        <th class="text-left py-2 px-3">Label / Canonical</th>
+        <th class="text-left py-2 px-3">Quality Snippet</th>
+        <th class="text-left py-2 px-3">Status</th>
+        <th class="text-right py-2 px-3">Actions</th>
+      </tr>
+    </thead>
+    <tbody>
+      {% for row in rows %}
+      {% set _raw_speaker = row.speaker or '' %}
+      {% if _raw_speaker[:8] == 'SPEAKER_' %}
+        {% set _speaker_index_digits = _raw_speaker[8:] %}
+        {% set _avatar_label = 'S' ~ (_speaker_index_digits.lstrip('0') or '0') %}
+      {% else %}
+        {% set _avatar_label = _raw_speaker[:2]|upper %}
+      {% endif %}
+      {% set _recommended_snippets = row.clean_snippets | selectattr('recommended') | list %}
+      {% set _best_snippet = _recommended_snippets[0] if _recommended_snippets else (row.clean_snippets[0] if row.clean_snippets else None) %}
+      {% set _no_snippet_reason = (row.snippet_ui_state.label if row.snippet_ui_state and row.snippet_ui_state.label else '') %}
+      <tr class="border-b border-slate-100 align-middle" data-testid="speaker-review-row">
+        <td class="py-2 px-3">
+          <div class="flex items-center gap-2">
+            <div class="size-8 bg-primary/10 text-primary rounded-full flex items-center justify-center font-bold text-xs shrink-0">{{ _avatar_label }}</div>
+            <span class="text-xs font-mono text-slate-500">{{ row.speaker }}</span>
+          </div>
+        </td>
+        <td class="py-2 px-3">
+          {% if row.global_voice_profile_id or row.local_display_name %}
+          <div class="text-sm font-semibold text-slate-900">{{ row.display_label }}</div>
+          <div class="text-[11px] text-slate-500">{{ row.mapping_title }}</div>
+          {% else %}
+          <div class="text-sm text-slate-400 italic">Unknown Speaker</div>
+          <div class="text-[11px] text-slate-500">{{ row.mapping_title }}</div>
+          {% endif %}
+          {% if row.low_confidence and row.assignment_threshold %}
+          <div class="text-[10px] text-amber-600 mt-0.5">Below auto-match threshold {{ '%.2f'|format(row.assignment_threshold) }}.</div>
+          {% endif %}
