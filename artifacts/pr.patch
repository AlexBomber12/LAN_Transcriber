+    assert stop.chunk_total == 5
+    assert (
+        "llm request cancelled checkpoint=llm_chunk_request chunk_index=2 chunk_total=5"
+        in (tmp_path / "logs" / "llm-stop.log").read_text(encoding="utf-8")
+    )
 
 
