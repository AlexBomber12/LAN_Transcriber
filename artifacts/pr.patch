+      </tr>
+    </thead>
+    <tbody>
+      {% for row in rows %}
+      <tr>
+        <td><code>{{ row.speaker }}</code></td>
+        <td>{{ row.turn_count }}</td>
+        <td>{{ '%.2f'|format(row.duration_sec or 0.0) }}</td>
+        <td title="{{ row.preview_text }}" style="white-space:normal;max-width:300px">{{ row.preview_text or '—' }}</td>
+        <td style="white-space:normal;max-width:260px">
+          {% if row.voice_profile_name %}
+          <div><strong>{{ row.voice_profile_name }}</strong></div>
+          <div style="margin-top:4px;color:#555">Displays as {{ row.display_label }} in exports.</div>
