#Plaud credentials
PLAUD_EMAIL=
PLAUD_PASSWORD=

# External LLM (OpenAI-compatible)
LLM_BASE_URL=http://192.168.0.4:8000
LLM_API_KEY=
# Required: no fallback model is used at runtime.
LLM_MODEL=gpt-oss:120b
# Recommended for larger JSON responses and slower local models
LLM_TIMEOUT_SECONDS=600
LLM_MAX_TOKENS=1024
LLM_MAX_TOKENS_RETRY=2048
LLM_CHUNK_MAX_CHARS=6000
LLM_CHUNK_OVERLAP_CHARS=600
LLM_CHUNK_TIMEOUT_SECONDS=120
LLM_LONG_TRANSCRIPT_THRESHOLD_CHARS=6000
# Optional: set only if merge pass needs a larger budget than chunk extracts.
# LLM_MERGE_MAX_TOKENS=2048
# Optional local test stub (file with plain text or JSON response payload)
# LLM_MOCK_RESPONSE_PATH=/data/secrets/mock_llm_response.json

# Runtime paths (LAN_ prefixed)
LAN_ENV=dev
LAN_DATA_ROOT=/data
LAN_RECORDINGS_ROOT=/data/recordings
LAN_SPEAKER_DB=/data/db/speaker_bank.yaml
LAN_VOICES_DIR=/data/voices
LAN_UNKNOWN_DIR=/data/recordings/unknown
LAN_TMP_ROOT=/data/tmp
LAN_PROM_SNAPSHOT_PATH=/data/metrics.snap
LAN_DB_PATH=/data/db/app.db
LAN_SQLITE_BUSY_TIMEOUT_MS=30000
LAN_REDIS_URL=redis://redis:6379/0
LAN_RQ_QUEUE_NAME=lan-transcriber
LAN_DIARIZATION_MODEL_ID=pyannote/speaker-diarization-3.1
LAN_VAD_METHOD=silero
LAN_ASR_MULTILINGUAL_MODE=auto
# Optional upload cap per file in bytes (set to enable)
# UPLOAD_MAX_BYTES=1073741824
LAN_CALENDAR_EXPAND_PAST_DAYS=30
LAN_CALENDAR_EXPAND_FUTURE_DAYS=180
LAN_CALENDAR_FETCH_TIMEOUT_SECONDS=15
LAN_CALENDAR_FETCH_MAX_BYTES=2000000
LAN_CALENDAR_FETCH_MAX_REDIRECTS=5
QUARANTINE_RETENTION_DAYS=7
HF_TOKEN=
# Optional fallback token var name accepted by huggingface_hub
# HUGGINGFACE_HUB_TOKEN=
HF_HOME=/data/hf
TRANSFORMERS_CACHE=/data/hf/transformers

ROUTING_AUTO_SELECT_THRESHOLD=0.65

# Plaud fetcher (beta)
FETCH_INTERVAL_SEC=300

# Optional metadata
TRANSCRIBER_VERSION=local
TRANSCRIBER_DOCKER_TARGET=runtime-full
TRANSCRIBER_PULL_POLICY=never
LANG_DEFAULT=ru

# LAN binding hardening (bind published API port to loopback by default)
LAN_API_BIND_HOST=127.0.0.1
LAN_API_PORT=7860

# Legacy fallback (kept for backwards compatibility)
# PROM_SNAPSHOT_PATH=/data/metrics.snap

# Optional prebuilt image (if set, also set TRANSCRIBER_PULL_POLICY=always)
# TRANSCRIBER_IMAGE=ghcr.io/alexbomber12/lan-transcriber:latest
